//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
@taskworld:registry=https://npm.pkg.github.com

# Match the value recorded in pnpm-lock.yaml (settings.autoInstallPeers) so that
# frozen installs on pnpm 10+ (whose default flipped to true) do not fail with
# ERR_PNPM_LOCKFILE_CONFIG_MISMATCH.
auto-install-peers=false
